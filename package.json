{
  "name": "hs-code-ver",
  "version": "2.0.0",
  "type": "module",
  "description": "System weryfikacji kodów celnych HS z bazą ISZTAR i systemami ostrzeżeń z uwierzytelnianiem",
  "keywords": [
    "hs-codes",
    "customs",
    "verification",
    "q4rail",
    "sanepid",
    "sanctions",
    "authentication"
  ],
  "author": "Q4Rail Sp. z o.o.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "hs-code.q4rail.com"
  },
  "homepage": "hs-code.q4rail.com",
  "scripts": {
    "test-sync": "node scripts/test-sync.js",
    "test-isztar": "node scripts/test-isztar.js",
    "delta-sync": "node scripts/delta-sync.js",
    "deploy": "cd backend && npx wrangler deploy",
    "dev": "cd backend && npx wrangler dev",
    "kv-test": "npx wrangler kv key get --namespace-id=d4e909bdc6114613ab76635fadb855b2 \"HS_METADATA\" --remote",
    "sanctions-list": "node scripts/manage-sanctions.js list",
    "sanctions-update": "node scripts/manage-sanctions.js update",
    "sanctions-help": "node scripts/manage-sanctions.js help",
    "controlled-list": "node scripts/manage-controlled.js list",
    "controlled-update": "node scripts/manage-controlled.js update",
    "controlled-help": "node scripts/manage-controlled.js help",
    "health": "curl -s https://hs-code-verifier-api.konto-dla-m-w-q4r.workers.dev/health | jq .",
    "stats": "curl -s https://hs-code-verifier-api.konto-dla-m-w-q4r.workers.dev/stats | jq .",
    "verify": "echo 'Użyj: npm run verify -- --code=0101'",
    "test": "npm run test-sync && npm run test-isztar",
    "setup-kv": "node scripts/setup-kv.js",
    "full-deploy": "npm run delta-sync && npm run deploy",
    "init-admin": "node scripts/init-admin.js",
    "user-list": "node scripts/user-manager.js list",
    "user-create": "node scripts/user-manager.js create",
    "user-delete": "node scripts/user-manager.js delete",
    "user-help": "node scripts/user-manager.js help",
    "test-login": "curl -X POST https://hs-code-verifier-api.konto-dla-m-w-q4r.workers.dev/api/auth/login -H 'Content-Type: application/json' -d '{\"username\":\"test\",\"password\":\"test\"}'",
    "test-auth": "echo 'Użyj: curl -H \"Authorization: Bearer TOKEN\" https://hs-code-verifier-api.konto-dla-m-w-q4r.workers.dev/verify -X POST -H \"Content-Type: application/json\" -d \\'{\\\"code\\\":\\\"0101\\\"}\\''"
  },
  "bin": {
    "hs-verify": "./scripts/cli-verifier.js"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "readline-sync": "^1.4.10"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "files": [
    "scripts/",
    "backend/",
    "frontend/",
    ".github/"
  ]
}
